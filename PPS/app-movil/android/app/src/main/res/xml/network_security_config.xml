<?xml version="1.0" encoding="utf-8"?>
<!--
  android/app/src/main/res/xml/network_security_config.xml

  SEGURIDAD (MASVS-NETWORK-1 / M5 — Insecure Communication):
  ─ Deshabilita todo tráfico HTTP en texto plano (cleartext).
  ─ Fuerza HTTPS/TLS para todas las conexiones.
  ─ Solo permite conexiones a dominios de la API oficial.
  ─ En debug: permite conexión local (10.0.2.2 = emulador → host).

  REFERENCIA:
  https://developer.android.com/training/articles/security-config
-->
<network-security-config>

  <!-- Política base: sin cleartext en ningún dominio -->
  <base-config cleartextTrafficPermitted="false">
    <trust-anchors>
      <!-- Solo confiar en CAs del sistema (no en CAs de usuario) -->
      <certificates src="system"/>
      <!-- NUNCA incluir: <certificates src="user"/> en producción -->
    </trust-anchors>
  </base-config>

  <!-- Dominio de la API de producción -->
  <domain-config cleartextTrafficPermitted="false">
    <domain includeSubdomains="true">api.tuClinica.com</domain>
    <trust-anchors>
      <certificates src="system"/>
    </trust-anchors>
    <!-- Certificate Pinning a nivel de red (segunda capa de protección) -->
    <!-- El pinning principal se realiza en certificate_pinning.dart    -->
    <pin-set expiration="2027-01-01">
      <!-- SHA-256 del Subject Public Key Info (SPKI) del certificado -->
      <pin digest="SHA-256">AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=</pin>
      <!-- Backup pin para rotación sin interrupción del servicio     -->
      <pin digest="SHA-256">BBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBBB=</pin>
    </pin-set>
  </domain-config>

  <!--
    SOLO PARA DESARROLLO LOCAL — ELIMINAR EN PRODUCCIÓN
    Permite cleartext solo al emulador Android ↔ host
  -->
  <!-- debug-overrides>
    <trust-anchors>
      <certificates src="user"/>
    </trust-anchors>
    <domain-config cleartextTrafficPermitted="true">
      <domain>10.0.2.2</domain>
      <domain>localhost</domain>
    </domain-config>
  </debug-overrides -->

</network-security-config>
